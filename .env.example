# GeekShop HQ — Server Environment

# Required: a 32+ char random string for the admin session cookie
ADMIN_SESSION_SECRET=change-me-to-a-real-32-char-random-string

# Optional: SMTP for outbound email (Gmail app password, or any SMTP server)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@geekshop.ca
SMTP_PASS=your-app-password
SMTP_FROM=GeekShop HQ <support@geekshop.ca>

# Optional: Google Chat webhook fallback (not used in v1, future)

# Optional: AI providers (defaults below; override only if you want to swap)
AI_HIGH_PROVIDER=codex
AI_CHEAP_PROVIDER=minimax
# Codex / OpenAI (for high-reasoning)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Minimax / Johnny5 (for cheap-classify) — handled by Hermes
# Gemini (optional tertiary fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Server bind
PORT=5050
HOST=0.0.0.0
NODE_ENV=development
APP_URL=http://localhost:5173
