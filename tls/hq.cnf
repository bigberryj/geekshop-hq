[req]
default_bits       = 2048
prompt             = no
default_md         = sha256
distinguished_name = dn
req_extensions     = v3_req

[dn]
C  = CA
ST = BC
O  = GeekShop HQ
OU = Internal
CN = hq.local

[v3_req]
keyUsage         = critical, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth
subjectAltName   = @alt_names

[alt_names]
# Tailscale hostname & IP
DNS.1 = bigbai.tail136908.ts.net
DNS.2 = bigbai
IP.1  = 100.96.13.84
# LAN hostname & IP
DNS.3 = bigbai.lan
IP.2  = 192.168.1.168
# Loopback fallbacks (some browsers test this)
DNS.4 = localhost
IP.3  = 127.0.0.1