# GeekShop HQ - Server Environment Template
# Copy this file to .env and fill in real values. NEVER commit .env.

ADMIN_SESSION_SECRET=change-me-to-32-random-bytes-please

# === AI Providers ===
# Primary: MiniMax M3 via Anthropic-compatible endpoint.
# Get a key at: https://minimax.io (your ChatGPT/MiniMax sub, separate static key)
MINIMAX_API_KEY=your-minimax-api-key-here
# MINIMAX_MODEL=MiniMax-M3
# MINIMAX_BASE_URL=https://api.minimax.io/anthropic

# Optional secondary: OpenAI Platform (Codex / gpt-4o-mini).
# Only set if you have a separate OpenAI Platform account with billing.
# Note: a ChatGPT Plus/Pro subscription does NOT provide this key.
# OPENAI_API_KEY=sk-proj-...

# === Gmail (byron@geekshop.ca) ===
# Generate an App Password at https://myaccount.google.com/apppasswords
# Requires 2FA enabled on the account.
BYRON_GMAIL_USER=you@gmail.com
BYRON_GMAIL_APP_PASSWORD=your-16-char-app-password
BYRON_GMAIL_POLL_INTERVAL_MIN=30
BYRON_GMAIL_AUTO_CREATE_TICKETS=true

# === SMTP (outbound) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=GeekShop HQ <support@example.com>

# === Server bind ===
PORT=5050
HOST=0.0.0.0
NODE_ENV=development
APP_URL=http://localhost:5173
